{%- comment -%} SHIELD — Comparador Antes/Después con línea deslizable {%- endcomment -%}
<style>
  .shield-ba{--ink:#0B0B0C;--bone:#F4F1EA;--g1:#E7CD8C;--g2:#967434;--gold:linear-gradient(135deg,#E7CD8C,#967434);--fd:"Big Shoulders Display",Impact,sans-serif;--fm:"Space Mono",monospace;--fb:-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;max-width:560px;margin:0 auto;padding:28px 22px;font-family:var(--fb);text-align:center}
  .shield-ba__eyebrow{font-family:var(--fm);font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:var(--g2);margin:0 0 8px}
  .shield-ba__title{font-family:var(--fd);font-weight:700;text-transform:uppercase;line-height:1.05;color:var(--ink);font-size:clamp(22px,5vw,34px);margin:0 0 18px}
  .shield-ba__frame{position:relative;width:100%;border-radius:12px;overflow:hidden;border:1px solid rgba(11,11,12,.12);touch-action:none;cursor:ew-resize;user-select:none;-webkit-user-select:none;background:#e9e6dd}
  .shield-ba__layer{position:absolute;inset:0}
  .shield-ba__layer img{width:100%;height:100%;object-fit:cover;display:block;pointer-events:none}
  .shield-ba__before{clip-path:inset(0 50% 0 0)}
  .shield-ba__ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;text-align:center;padding:16px}
  .shield-ba__ph span{font-family:var(--fm);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#6b6b70;max-width:200px}
  .shield-ba__ph--b{background:#d9d5ca}
  .shield-ba__ph--a{background:#eceadf}
  .shield-ba__divider{position:absolute;top:0;bottom:0;left:50%;width:3px;background:var(--gold);transform:translateX(-50%);pointer-events:none}
  .shield-ba__grip{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:44px;height:44px;border-radius:50%;background:var(--gold);color:#1a1408;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;box-shadow:0 4px 14px rgba(0,0,0,.3)}
  .shield-ba__tag{position:absolute;bottom:12px;font-family:var(--fm);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--bone);background:rgba(11,11,12,.72);padding:5px 11px;border-radius:999px}
  .shield-ba__tag--b{left:12px}
  .shield-ba__tag--a{right:12px}
  .shield-ba__caption{font-size:12px;line-height:1.5;color:#7a7a82;margin:14px 0 0}
</style>

{%- assign ratio = section.settings.ratio | default: '4 / 5' -%}
<div class="shield-ba" id="ba-{{ section.id }}">
  {%- if section.settings.eyebrow != blank -%}<p class="shield-ba__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
  {%- if section.settings.title != blank -%}<h2 class="shield-ba__title">{{ section.settings.title }}</h2>{%- endif -%}

  <div class="shield-ba__frame" style="aspect-ratio:{{ ratio }}">
    <div class="shield-ba__layer shield-ba__after">
      {%- if section.settings.after_image != blank -%}
        <img src="{{ section.settings.after_image | image_url: width: 1200 }}" alt="{{ section.settings.after_label | escape }}" loading="lazy">
      {%- else -%}
        <div class="shield-ba__ph shield-ba__ph--a"><span>Subí la foto «{{ section.settings.after_label | default: 'Después' }}» de la espalda</span></div>
      {%- endif -%}
    </div>
    <div class="shield-ba__layer shield-ba__before">
      {%- if section.settings.before_image != blank -%}
        <img src="{{ section.settings.before_image | image_url: width: 1200 }}" alt="{{ section.settings.before_label | escape }}" loading="lazy">
      {%- else -%}
        <div class="shield-ba__ph shield-ba__ph--b"><span>Subí la foto «{{ section.settings.before_label | default: 'Antes' }}» de la espalda</span></div>
      {%- endif -%}
    </div>
    <div class="shield-ba__divider"><span class="shield-ba__grip">⟺</span></div>
    {%- if section.settings.before_label != blank -%}<span class="shield-ba__tag shield-ba__tag--b">{{ section.settings.before_label }}</span>{%- endif -%}
    {%- if section.settings.after_label != blank -%}<span class="shield-ba__tag shield-ba__tag--a">{{ section.settings.after_label }}</span>{%- endif -%}
  </div>

  {%- if section.settings.caption != blank -%}<p class="shield-ba__caption">{{ section.settings.caption }}</p>{%- endif -%}
</div>

<script>
  (function(){
    var root = document.getElementById('ba-{{ section.id }}');
    if(!root) return;
    var frame = root.querySelector('.shield-ba__frame');
    var before = root.querySelector('.shield-ba__before');
    var divider = root.querySelector('.shield-ba__divider');
    var dragging = false;
    function setPos(clientX){
      var r = frame.getBoundingClientRect();
      var p = (clientX - r.left) / r.width * 100;
      if(p < 0) p = 0; if(p > 100) p = 100;
      before.style.clipPath = 'inset(0 ' + (100 - p) + '% 0 0)';
      divider.style.left = p + '%';
    }
    frame.addEventListener('pointerdown', function(e){ dragging = true; setPos(e.clientX); });
    window.addEventListener('pointermove', function(e){ if(dragging) setPos(e.clientX); });
    window.addEventListener('pointerup', function(){ dragging = false; });
  })();
</script>

{% schema %}
{
  "name": "SHIELD · Antes/Después",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Bajada", "default": "Resultados con el uso" },
    { "type": "text", "id": "title", "label": "Título", "default": "Deslizá para ver el antes y después" },
    { "type": "image_picker", "id": "before_image", "label": "Imagen ANTES (espalda)" },
    { "type": "image_picker", "id": "after_image", "label": "Imagen DESPUÉS (espalda)" },
    { "type": "text", "id": "before_label", "label": "Etiqueta izquierda", "default": "Antes" },
    { "type": "text", "id": "after_label", "label": "Etiqueta derecha", "default": "Después" },
    { "type": "select", "id": "ratio", "label": "Proporción", "default": "4 / 5",
      "options": [
        { "value": "4 / 5", "label": "Vertical (4:5)" },
        { "value": "3 / 4", "label": "Vertical alto (3:4)" },
        { "value": "1 / 1", "label": "Cuadrado (1:1)" },
        { "value": "16 / 9", "label": "Horizontal (16:9)" }
      ]
    },
    { "type": "text", "id": "caption", "label": "Aclaración", "default": "Deslizá la línea para comparar. Imágenes ilustrativas." }
  ],
  "presets": [{ "name": "SHIELD · Antes/Después" }]
}
{% endschema %}
