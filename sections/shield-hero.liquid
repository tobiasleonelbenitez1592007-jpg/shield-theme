{%- comment -%} SHIELD landing — Hero (Obsidiana & Oro). Carga tipografias de marca. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700;900&family=Italiana&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<style>
  .shield-lp{
    --sh-black:#0B0B0C;--sh-gold1:#E7CD8C;--sh-gold2:#967434;--sh-bone:#F4F1EA;
    --sh-gold:linear-gradient(135deg,#E7CD8C 0%,#967434 100%);
    --sh-font-display:"Big Shoulders Display",Impact,sans-serif;
    --sh-font-serif:"Italiana",Georgia,serif;
    --sh-font-mono:"Space Mono","Courier New",monospace;
  }
  .shield-hero{background:var(--sh-black);color:var(--sh-bone);position:relative;overflow:hidden;padding:80px 24px 96px;text-align:center}
  .shield-hero__inner{max-width:760px;margin:0 auto;position:relative;z-index:2}
  .shield-hero__logo{font-family:var(--sh-font-serif);letter-spacing:.18em;font-size:clamp(22px,4vw,30px);text-transform:uppercase;margin:0 0 8px}
  .shield-hero__eyebrow{font-family:var(--sh-font-mono);font-size:11px;letter-spacing:.32em;text-transform:uppercase;color:var(--sh-gold1);margin:0 0 28px;opacity:.9}
  .shield-hero__title{font-family:var(--sh-font-display);font-weight:900;line-height:.95;letter-spacing:.01em;text-transform:uppercase;font-size:clamp(40px,9vw,82px);margin:0 0 20px}
  .shield-hero__title .g{background:var(--sh-gold);-webkit-background-clip:text;background-clip:text;color:transparent}
  .shield-hero__sub{font-size:clamp(16px,2.4vw,19px);line-height:1.6;max-width:560px;margin:0 auto 14px;color:#cfcabb}
  .shield-hero__img{max-width:340px;width:70%;margin:30px auto 6px;display:block}
  .shield-badge{display:inline-flex;align-items:center;gap:10px;font-family:var(--sh-font-mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;border:1px solid rgba(231,205,140,.4);border-radius:999px;padding:9px 18px;margin:24px 0 28px;color:var(--sh-gold1)}
  .shield-badge .num{font-family:var(--sh-font-display);font-weight:900;font-size:20px;background:var(--sh-gold);-webkit-background-clip:text;background-clip:text;color:transparent}
  .shield-btn{display:inline-block;font-family:var(--sh-font-display);font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:18px;background:var(--sh-gold);color:#1a1408;padding:18px 44px;border-radius:6px;text-decoration:none;box-shadow:0 10px 30px rgba(150,116,52,.35);transition:transform .15s ease,box-shadow .15s ease}
  .shield-btn:hover{transform:translateY(-2px);box-shadow:0 14px 38px rgba(150,116,52,.5)}
  .shield-hero__trust{font-family:var(--sh-font-mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#8b8779;margin-top:18px}
  .shield-hero__glow{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(150,116,52,.22),transparent 60%);top:-180px;left:50%;transform:translateX(-50%);z-index:1;pointer-events:none}
</style>

<div class="shield-lp">
  <section class="shield-hero">
    <div class="shield-hero__glow"></div>
    <div class="shield-hero__inner">
      {%- if section.settings.logo_text != blank -%}<p class="shield-hero__logo">{{ section.settings.logo_text }}</p>{%- endif -%}
      {%- if section.settings.eyebrow != blank -%}<p class="shield-hero__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h1 class="shield-hero__title">{{ section.settings.title }}</h1>
      {%- if section.settings.subtitle != blank -%}<p class="shield-hero__sub">{{ section.settings.subtitle }}</p>{%- endif -%}
      {%- if section.settings.image != blank -%}
        <img class="shield-hero__img" src="{{ section.settings.image | image_url: width: 680 }}" alt="{{ section.settings.title | escape }}" loading="eager" width="340">
      {%- endif -%}
      {%- if section.settings.badge_text != blank -%}
        <div class="shield-badge"><span class="num">{{ section.settings.badge_num }}</span>{{ section.settings.badge_text }}</div>
      {%- endif -%}
      <div>
        <a href="{{ section.settings.cta_link | default: '#shield-oferta' }}" class="shield-btn">{{ section.settings.cta_label }}</a>
      </div>
      {%- if section.settings.trust_text != blank -%}<p class="shield-hero__trust">{{ section.settings.trust_text }}</p>{%- endif -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SHIELD · Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo (texto)", "default": "SHIELD" },
    { "type": "text", "id": "eyebrow", "label": "Bajada superior", "default": "Tecnología antiacné para hombres" },
    { "type": "textarea", "id": "title", "label": "Titular", "default": "Adiós al acné de la espalda" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "El gel antiacné corporal de limpieza profunda. Se usa en la ducha, como un jabón. Todos los días, sin rutinas complicadas." },
    { "type": "image_picker", "id": "image", "label": "Imagen del producto" },
    { "type": "text", "id": "badge_num", "label": "Número de oferta", "default": "50%" },
    { "type": "text", "id": "badge_text", "label": "Texto de oferta", "default": "OFF + envío gratis esta semana" },
    { "type": "text", "id": "cta_label", "label": "Texto del botón", "default": "Quiero el mío" },
    { "type": "url", "id": "cta_link", "label": "Link del botón (producto)" },
    { "type": "text", "id": "trust_text", "label": "Línea de confianza", "default": "30 días de garantía · Envío gratis a todo el país" }
  ],
  "presets": [{ "name": "SHIELD · Hero" }]
}
{% endschema %}
